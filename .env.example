# Hugging Face model download (required unless model already exists in MODEL_DIR)
HUGGINGFACE_REPO_ID=djmustakim/projects
HUGGINGFACE_MODEL_FILENAME=brain_tumor_model.pth

# Optional Hugging Face token for private repositories
# HUGGINGFACE_TOKEN=hf_xxxxxxxx

# Server
PORT=8080
LOG_LEVEL=INFO

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Paths (defaults work for local and Docker)
# MODEL_DIR=./models
# UPLOAD_DIR=./uploads
# LABELS_PATH=./labels.txt

# Gunicorn tuning
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=120
